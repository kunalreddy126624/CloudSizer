ALLOCATOR_DATABASE_URL=postgresql://cloudsizer:cloudsizer@localhost:5432/cloudsizer
ALLOCATOR_TERRAFORM_ARTIFACT_DIR=app/data/allocator_artifacts
ALLOCATOR_ACCOUNT_EMAIL_DOMAIN=allocator.local
ALLOCATOR_MOCK_CLOUD_CONTROL_PLANE=true
ALLOCATOR_APPROVAL_REQUIRED=true
AWS_REGION=us-east-1
REDIS_URL=redis://localhost:6379/0
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8068
RBAC_DATABASE_URL=postgresql+psycopg://cloudsizer:cloudsizer@localhost:5432/cloudsizer
RBAC_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
RBAC_JWT_ALGORITHM=HS256
RBAC_ACCESS_TOKEN_EXPIRY_MINUTES=60
RBAC_JWT_ISSUER=cloudsizer
RBAC_JWT_AUDIENCE=cloudsizer-api
NOODLE_ENVIRONMENT=development
NOODLE_WORKFLOW_BACKEND=temporal
NOODLE_EVENT_BACKBONE=kafka
NOODLE_METADATA_BACKEND=datahub
NOODLE_LAKEHOUSE_FORMAT=iceberg
NOODLE_SERVING_API_BASE=/noodle
NOODLE_LLM_PROVIDER=openai-compatible-gateway
